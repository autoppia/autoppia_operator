# Example env for local dev/eval. Do not commit real secrets.

# Used for local eval/task-generation. In the subnet sandbox, requests go through
# a gateway and OPENAI_API_KEY is typically NOT required.
OPENAI_API_KEY=

# Subnet validator injects something like:
# OPENAI_BASE_URL=http://sandbox-gateway:9000/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model used by agent.py
OPENAI_MODEL=gpt-5.2
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=350

# Completion checker (second /act LLM call, defaults enabled, use smaller model)
AGENT_ENABLE_COMPLETION_CHECK=1
AGENT_COMPLETION_MODEL=gpt-4o-mini
AGENT_COMPLETION_MIN_CONFIDENCE=0.82
AGENT_COMPLETION_TEMPERATURE=0.0
AGENT_COMPLETION_MAX_TOKENS=120

# Local eval runner
START_AGENT_SERVER=1
AGENT_RETURN_METRICS=1
WEB_AGENT_ID=1

# SMTP notifications (notification toolchain)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_DEFAULT_TO=
SMTP_USE_SSL=0
SMTP_USE_TLS=1
SMTP_TIMEOUT=20

# RunPod automation
RUNPOD_API_KEY=

# Bittensor/IWAP/sn36 operator context
SN36_COLDKEY=
SN36_HOTKEY=
SN36_NETUID=36
SN36_NETWORK=finney
SN36_CHAIN_ENDPOINT=
SN36_GITHUB_URL=
SN36_AGENT_NAME=
SN36_AGENT_IMAGE=
SN36_TARGET_ROUND=
SN36_SEASON=
SN36_MINER_CLI=
SN36_TOP_NODES=
IWAP_BASE_URL=https://api-leaderboard.autoppia.com
IWAP_API_TOKEN=
IWAP_MOCK_DATA=
