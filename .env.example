# Example env for local dev/eval. Do not commit real secrets.

# Used for local eval/task-generation. In the subnet sandbox, requests go through
# a gateway and OPENAI_API_KEY is typically NOT required.
OPENAI_API_KEY=

# Subnet validator injects something like:
# OPENAI_BASE_URL=http://sandbox-gateway:9000/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model used by agent.py
OPENAI_MODEL=gpt-5.2
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=350

# Completion checker (second /act LLM call, defaults enabled, use smaller model)
AGENT_ENABLE_COMPLETION_CHECK=1
AGENT_COMPLETION_MODEL=gpt-4o-mini
AGENT_COMPLETION_MIN_CONFIDENCE=0.82
AGENT_COMPLETION_TEMPERATURE=0.0
AGENT_COMPLETION_MAX_TOKENS=120

# Local eval runner
START_AGENT_SERVER=1
AGENT_RETURN_METRICS=1
WEB_AGENT_ID=1
